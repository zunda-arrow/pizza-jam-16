[node name="Comment" parent="." unique_id=2120769087 instance=ExtResource("4_7e6m4")]
offset_left = 60.0
offset_top = -295.0
offset_right = 784.0
offset_bottom = -57.0
text = "This scene controls the hoard of ants visuals. I'm finding its very hard to proerly keep track of every ants location, so I will just cheese it."

[node name="Comment2" parent="." unique_id=1845539562 instance=ExtResource("4_7e6m4")]
offset_left = 1601.0
offset_top = -223.0
offset_right = 2411.0
offset_bottom = 680.0
text = "In the future this scene will probably remove ants from loops that dont connect to the center for example. It might feel bad if you actually lose an ant, which I dont want.

The second reason, is that buildings will be easier to understand and program if they dont actually need to wait for an ant. This will also make the game more snappy because there will be less waiting.

Right now, I think the end goal will be to have an appropriate amount of ants walking from active buildings to the center. I think this will feel more than anty enough."
